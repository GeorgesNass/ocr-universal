## ============================================
## OCR CONFIGURATION
## ============================================
USE_TESSERACT=true
USE_GOOGLE_VISION=false
USE_TIKA=true
USE_PYPDF2=true
USE_PDFTOTEXT=true
USE_PDF2IMAGE=true

## ============================================
## EXTRACTION OPTIONS
## ============================================
USE_BEAUTIFULSOUP=true
USE_HTML2TEXT=false
USE_URLLIB=false

INCLUDE_DOCX_HEADERS=true
INCLUDE_DOCX_TABLES=true

USE_DETAILED_EXCEL_EXTRACTION=false

USE_DETAILED_PPTX_EXTRACTION=false

## ============================================
## DIRECTORIES
## ============================================
INPUT_DIR=data/input
CONVERTED_DIR=data/converted
OUTPUT_DIR=data/output

## ============================================
## FILE MANAGEMENT
## ============================================
PRUNE_AFTER_PROCESS=false
MAX_PDF_SIZE_MB=50
CSV_SEPARATOR=\t
CSV_EXTENSION=.txt

## ============================================
## SYSTEM CONFIGURATION
## ============================================
PYTHON_ENV=python3.10

## ============================================
## LOGGING & DEBUG
## ============================================
LOG_TO_CONSOLE=true
DEBUG=true

